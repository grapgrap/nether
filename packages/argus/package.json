{
  "name": "@nether/argus",
  "type": "module",
  "bin": "./bin/bin.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:dist": "tsc -p tsconfig.build.json",
    "build:bin": "tsc -p tsconfig.bin.json",
    "build": "yarn build:dist && yarn build:bin",
    "watch": "yarn build --watch"
  },
  "devDependencies": {
    "@nether/tsconfig": "workspace:^",
    "@types/node": "^20.11.30",
    "eslint": "^8.57.0",
    "eslint-config-nether": "workspace:^",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@parcel/watcher": "^2.4.1",
    "clipanion": "^4.0.0-rc.3",
    "typanion": "^3.14.0"
  }
}
